# Build artifacts
dist/
dist-ssr/
coverage/

# Dependencies (installed in container)
node_modules/
e2e/node_modules/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
test-results/
playwright-report/

# Version control
.git/
.gitignore

# CI/CD
.github/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Environment files (secrets must not be baked into image)
.env
.env.local
.env.*.local

# Test artifacts
.nyc_output/
coverage/

# Temp files
*.tmp
*.temp

# Package manager alternative lockfiles (pnpm only)
package-lock.json
yarn.lock

# Editor
.editorconfig

# Husky
.husky/

# Yarn v2
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.pnp.*

# Misc
.allow-test-config-edits
