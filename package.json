{
  "main": "index.js",
  "repository": "git@github.p.com:Ronald-Cifuentes/vite-boilerplate.git",
  "author": "Ronald Cifuentes <ronald.cifuentes2020@gmail.com>",
  "license": "MIT",
  "name": "vite-boilerplate",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "commit": "npx gitmoji-cli -c",
    "gen": "npx generate-react-cli c",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "npm run lint && npm run format && npm run test",
    "cov": "npm run test \"$src\" -- --coverage --collectCoverageFrom=\"$(echo $src | sed 's/.spec//')\"",
    "prepare": "husky",
    "format": "prettier --write .",
    "lint": "eslint src --ext ts,tsx",
    "ts-check": "tsc --noEmit --skipLibCheck",
    "depcheck": "depcheck",
    "sonar:report": "./scripts/quality-gate-report.sh",
    "check:css": "node scripts/check-empty-css-rules.mjs"
  },
  "dependencies": {
    "@preact/signals-react": "3.10.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-icons": "^5.7.0",
    "typescript": "6.0.3",
    "vite": "8.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "21.1.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "30.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "@vitejs/plugin-react": "6.0.3",
    "commitlint-config-gitmoji": "2.3.1",
    "depcheck": "1.4.7",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "jest-transform-stub": "2.0.0",
    "prettier": "3.9.3",
    "sass": "1.101.0",
    "ts-jest": "29.4.11"
  },
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": "24.x"
  }
}
